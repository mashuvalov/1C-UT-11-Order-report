#Область ПрограммныйИнтерфейс

Функция СведенияОВнешнейОбработке() Экспорт
	
	ПараметрыРегистрации = Новый Структура;
	ПараметрыРегистрации.Вставить("Вид", "ДополнительнаяОбработка");
	ПараметрыРегистрации.Вставить("Наименование", "Проданные товары в чеках и заказах");
	ПараметрыРегистрации.Вставить("Версия", "1.0");
	ПараметрыРегистрации.Вставить("БезопасныйРежим", Истина);
	ПараметрыРегистрации.Вставить("Информация", "Уникальные товары из проведенных чеков ККМ и заказов клиентов за период, с артикулом, остатком и закупочной ценой.");
	ПараметрыРегистрации.Вставить("Назначение", Новый Массив);
	
	Команды = ПолучитьТаблицуКоманд();
	ДобавитьКоманду(Команды, "Отчет ""Проданные товары в чеках и заказах""", "ОткрытьФорму", "ОткрытиеФормы", Ложь);
	ПараметрыРегистрации.Вставить("Команды", Команды);
	
	Возврат ПараметрыРегистрации;
	
КонецФункции

Функция ПолучитьДанныеОтчета(ДатаОт, ДатаДо, ВидЗакупочнойЦены = Неопределено) Экспорт
	
	ПроверитьПериодОтчета(ДатаОт, ДатаДо);
	
	ДатаНачала = НачалоДня(ДатаОт);
	ДатаОкончания = КонецДня(ДатаДо);
	
	Если Не ЗначениеЗаполнено(ВидЗакупочнойЦены) Тогда
		ВидЗакупочнойЦены = НайтиЗакупочныйВидЦены();
	КонецЕсли;
	
	Попытка
		Возврат ВыполнитьЗапросПроданныхТоваров(ДатаНачала, ДатаОкончания, ВидЗакупочнойЦены, "ВНаличииОстаток");
	Исключение
		ПерваяОшибка = ОписаниеОшибки();
	КонецПопытки;
	
	Попытка
		Возврат ВыполнитьЗапросПроданныхТоваров(ДатаНачала, ДатаОкончания, ВидЗакупочнойЦены, "КоличествоОстаток");
	Исключение
		ВызватьИсключение "Не удалось сформировать отчет. Проверьте имена документов, регистров и поля остатка в запросе." 
			+ Символы.ПС + "Первая попытка: " + ПерваяОшибка
			+ Символы.ПС + "Вторая попытка: " + ОписаниеОшибки();
	КонецПопытки;
	
КонецФункции

Функция НайтиЗакупочныйВидЦены() Экспорт
	
	ВариантыНаименований = Новый Массив;
	ВариантыНаименований.Добавить("Закупочная");
	ВариантыНаименований.Добавить("Закупочные");
	ВариантыНаименований.Добавить("Цена закупки");
	ВариантыНаименований.Добавить("Закупочная цена");
	
	Для Каждого НаименованиеВидаЦены Из ВариантыНаименований Цикл
		ВидЦены = Справочники.ВидыЦен.НайтиПоНаименованию(НаименованиеВидаЦены, Истина);
		Если ЗначениеЗаполнено(ВидЦены) Тогда
			Возврат ВидЦены;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Справочники.ВидыЦен.ПустаяСсылка();
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьТаблицуКоманд()
	
	Команды = Новый ТаблицаЗначений;
	Команды.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("Использование", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("ПоказыватьОповещение", Новый ОписаниеТипов("Булево"));
	Команды.Колонки.Добавить("Модификатор", Новый ОписаниеТипов("Строка"));
	
	Возврат Команды;
	
КонецФункции

Процедура ДобавитьКоманду(Команды, Представление, Идентификатор, Использование, ПоказыватьОповещение)
	
	Команда = Команды.Добавить();
	Команда.Представление = Представление;
	Команда.Идентификатор = Идентификатор;
	Команда.Использование = Использование;
	Команда.ПоказыватьОповещение = ПоказыватьОповещение;
	Команда.Модификатор = "";
	
КонецПроцедуры

Процедура ПроверитьПериодОтчета(ДатаОт, ДатаДо)
	
	Если Не ЗначениеЗаполнено(ДатаОт) Тогда
		ВызватьИсключение "Не заполнена дата начала периода.";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДатаДо) Тогда
		ВызватьИсключение "Не заполнена дата окончания периода.";
	КонецЕсли;
	
	Если НачалоДня(ДатаОт) > НачалоДня(ДатаДо) Тогда
		ВызватьИсключение "Дата начала периода больше даты окончания периода.";
	КонецЕсли;
	
КонецПроцедуры

Функция ВыполнитьЗапросПроданныхТоваров(ДатаОт, ДатаДо, ВидЗакупочнойЦены, ИмяПоляОстатка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапросаПроданныхТоваров(ИмяПоляОстатка);
	Запрос.УстановитьПараметр("ДатаОт", ДатаОт);
	Запрос.УстановитьПараметр("ДатаДо", ДатаДо);
	Запрос.УстановитьПараметр("ДатаОстатков", ДатаДо);
	Запрос.УстановитьПараметр("ВидЗакупочнойЦены", ВидЗакупочнойЦены);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ПолучитьТекстЗапросаПроданныхТоваров(ИмяПоляОстатка)
	
	Возврат
	"ВЫБРАТЬ
	|	Продажи.Номенклатура КАК Номенклатура,
	|	СУММА(Продажи.Количество) КАК КоличествоПродано
	|ПОМЕСТИТЬ ПроданныеТовары
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЧекиТовары.Номенклатура КАК Номенклатура,
	|		ЧекиТовары.Количество КАК Количество
	|	ИЗ
	|		Документ.ЧекККМ.Товары КАК ЧекиТовары
	|	ГДЕ
	|		ЧекиТовары.Ссылка.Проведен = ИСТИНА
	|		И ЧекиТовары.Ссылка.Дата МЕЖДУ &ДатаОт И &ДатаДо
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЗаказыТовары.Номенклатура,
	|		ЗаказыТовары.Количество
	|	ИЗ
	|		Документ.ЗаказКлиента.Товары КАК ЗаказыТовары
	|	ГДЕ
	|		ЗаказыТовары.Ссылка.Проведен = ИСТИНА
	|		И ЗаказыТовары.Ссылка.Дата МЕЖДУ &ДатаОт И &ДатаДо) КАК Продажи
	|
	|СГРУППИРОВАТЬ ПО
	|	Продажи.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказыТовары.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаказыТовары.Количество) КАК КоличествоЗаказано
	|ПОМЕСТИТЬ ЗаказанныеТовары
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказыТовары
	|ГДЕ
	|	ЗаказыТовары.Ссылка.Проведен = ИСТИНА
	|	И ЗаказыТовары.Ссылка.Дата МЕЖДУ &ДатаОт И &ДатаДо
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказыТовары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Остатки.Номенклатура КАК Номенклатура,
	|	СУММА(Остатки." + ИмяПоляОстатка + ") КАК Остаток
	|ПОМЕСТИТЬ ОстаткиТоваров
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаОстатков, ) КАК Остатки
	|ГДЕ
	|	Остатки.Номенклатура В
	|		(ВЫБРАТЬ
	|			ПроданныеТовары.Номенклатура
	|		ИЗ
	|			ПроданныеТовары КАК ПроданныеТовары)
	|
	|СГРУППИРОВАТЬ ПО
	|	Остатки.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Цены.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(Цены.Цена) КАК ЗакупочнаяЦена
	|ПОМЕСТИТЬ ЗакупочныеЦены
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаОстатков, ВидЦены = &ВидЗакупочнойЦены) КАК Цены
	|ГДЕ
	|	Цены.Номенклатура В
	|		(ВЫБРАТЬ
	|			ПроданныеТовары.Номенклатура
	|		ИЗ
	|			ПроданныеТовары КАК ПроданныеТовары)
	|
	|СГРУППИРОВАТЬ ПО
	|	Цены.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПроданныеТовары.Номенклатура.Артикул КАК Артикул,
	|	ПроданныеТовары.Номенклатура КАК Номенклатура,
	|	ПроданныеТовары.КоличествоПродано КАК КоличествоПродано,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ОстаткиТоваров.Остаток, 0) - ЕСТЬNULL(ЗаказанныеТовары.КоличествоЗаказано, 0) < 0
	|			ТОГДА 0
	|		ИНАЧЕ ЕСТЬNULL(ОстаткиТоваров.Остаток, 0) - ЕСТЬNULL(ЗаказанныеТовары.КоличествоЗаказано, 0)
	|	КОНЕЦ КАК Остаток,
	|	ЕСТЬNULL(ЗакупочныеЦены.ЗакупочнаяЦена, 0) КАК ЗакупочнаяЦена
	|ИЗ
	|	ПроданныеТовары КАК ПроданныеТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстаткиТоваров КАК ОстаткиТоваров
	|		ПО ПроданныеТовары.Номенклатура = ОстаткиТоваров.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЗаказанныеТовары КАК ЗаказанныеТовары
	|		ПО ПроданныеТовары.Номенклатура = ЗаказанныеТовары.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЗакупочныеЦены КАК ЗакупочныеЦены
	|		ПО ПроданныеТовары.Номенклатура = ЗакупочныеЦены.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура";
	
КонецФункции

#КонецОбласти
