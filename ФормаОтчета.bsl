#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗаполнитьПериодПоУмолчанию();
	
КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда)
	
	СформироватьОтчетЗаПериод();
	
КонецПроцедуры

#КонецОбласти

#Область КлиентскиеПроцедуры

&НаКлиенте
Процедура СформироватьОтчетЗаПериод()
	
	Если Не ЗначениеЗаполнено(ДатаОт) Или Не ЗначениеЗаполнено(ДатаДо) Тогда
		Сообщить("Заполните период отчета.");
		Возврат;
	КонецЕсли;
	
	Если НачалоДня(ДатаОт) > НачалоДня(ДатаДо) Тогда
		Сообщить("Дата начала периода больше даты окончания периода.");
		Возврат;
	КонецЕсли;
	
	Попытка
		ТабличныйДокумент = СформироватьОтчетНаСервере(ДатаОт, ДатаДо);
		СохранитьВыбранныйПериод();
		ТабличныйДокумент.Показать("Проданные товары в чеках и заказах");
		Сообщить("Отчет сформирован.");
	Исключение
		Сообщить("Не удалось сформировать отчет: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПериодПоУмолчанию()
	
	Период = ПолучитьПериодПоУмолчаниюНаСервере();
	ДатаОт = Период.ДатаОт;
	ДатаДо = Период.ДатаДо;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьВыбранныйПериод()
	
	СохранитьВыбранныйПериодНаСервере(ДатаОт, ДатаДо);
	
КонецПроцедуры

#КонецОбласти

#Область СерверныеПроцедурыИФункции

&НаСервере
Функция ПолучитьПериодПоУмолчаниюНаСервере()
	
	ПериодПоУмолчанию = Новый Структура("ДатаОт, ДатаДо", НачалоМесяца(ТекущаяДата()), КонецМесяца(ТекущаяДата()));
	
	Попытка
		Период = ХранилищеОбщихНастроек.Загрузить("ПроданныеТоварыВЧекахИЗаказах", "Период");
	Исключение
		Возврат ПериодПоУмолчанию;
	КонецПопытки;
	
	Если ТипЗнч(Период) = Тип("Структура") Тогда
		Если Период.Свойство("ДатаОт")
			И Период.Свойство("ДатаДо")
			И ЗначениеЗаполнено(Период.ДатаОт)
			И ЗначениеЗаполнено(Период.ДатаДо) Тогда
			Возврат Новый Структура("ДатаОт, ДатаДо", Период.ДатаОт, Период.ДатаДо);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПериодПоУмолчанию;
	
КонецФункции

&НаСервере
Процедура СохранитьВыбранныйПериодНаСервере(ДатаОт, ДатаДо)
	
	Период = Новый Структура("ДатаОт, ДатаДо", ДатаОт, ДатаДо);
	
	Попытка
		ХранилищеОбщихНастроек.Сохранить("ПроданныеТоварыВЧекахИЗаказах", "Период", Период);
	Исключение
		Сообщить("Не удалось сохранить выбранный период отчета: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция СформироватьОтчетНаСервере(ДатаОт, ДатаДо)
	
	ОбъектОтчета = РеквизитФормыВЗначение("Объект");
	
	ВидЗакупочнойЦены = ОбъектОтчета.НайтиЗакупочныйВидЦены();
	ДанныеОтчета = ОбъектОтчета.ПолучитьДанныеОтчета(ДатаОт, ДатаДо, ВидЗакупочнойЦены);
	
	Возврат ПолучитьТабличныйДокументОтчета(ДанныеОтчета, ДатаОт, ДатаДо, ВидЗакупочнойЦены);
	
КонецФункции

#КонецОбласти

#Область ВыводОтчета

&НаСервере
Функция ПолучитьТабличныйДокументОтчета(ДанныеОтчета, ДатаОт, ДатаДо, ВидЗакупочнойЦены)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	НастроитьШиринуКолонок(ТабличныйДокумент);
	
	УстановитьТекстЯчейки(ТабличныйДокумент, 1, 1, "Проданные товары в чеках и заказах");
	ОформитьЗаголовокОтчета(ТабличныйДокумент);
	УстановитьТекстЯчейки(ТабличныйДокумент, 2, 1, "Период:");
	УстановитьТекстЯчейки(ТабличныйДокумент, 2, 2, Формат(ДатаОт, "ДФ=dd.MM.yyyy") + " - " + Формат(ДатаДо, "ДФ=dd.MM.yyyy"));
	УстановитьТекстЯчейки(ТабличныйДокумент, 3, 1, "Вид закупочной цены:");
	УстановитьТекстЯчейки(ТабличныйДокумент, 3, 2, ПредставлениеВидаЦены(ВидЗакупочнойЦены));
	
	Если ДанныеОтчета.Количество() = 0 Тогда
		УстановитьТекстЯчейки(ТабличныйДокумент, 5, 1, "За выбранный период проведенных чеков и заказов с товарами не найдено.");
		Возврат ТабличныйДокумент;
	КонецЕсли;
	
	НомерСтроки = 5;
	ВывестиСтрокуШапки(ТабличныйДокумент, НомерСтроки);
	ОформитьШапкуТаблицы(ТабличныйДокумент, НомерСтроки);
	
	Для Каждого СтрокаДанных Из ДанныеОтчета Цикл
		НомерСтроки = НомерСтроки + 1;
		ВывестиСтрокуТовара(ТабличныйДокумент, НомерСтроки, СтрокаДанных);
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

&НаСервере
Процедура НастроитьШиринуКолонок(ТабличныйДокумент)
	
	УстановитьШиринуКолонки(ТабличныйДокумент, 1, 18);
	УстановитьШиринуКолонки(ТабличныйДокумент, 2, 45);
	УстановитьШиринуКолонки(ТабличныйДокумент, 3, 16);
	УстановитьШиринуКолонки(ТабличныйДокумент, 4, 16);
	УстановитьШиринуКолонки(ТабличныйДокумент, 5, 18);
	
КонецПроцедуры

&НаСервере
Процедура ВывестиСтрокуШапки(ТабличныйДокумент, НомерСтроки)
	
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 1, "Артикул");
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 2, "Номенклатура");
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 3, "Продано");
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 4, "Остаток");
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 5, "Закупочная цена");
	
КонецПроцедуры

&НаСервере
Процедура ВывестиСтрокуТовара(ТабличныйДокумент, НомерСтроки, СтрокаДанных)
	
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 1, Строка(СтрокаДанных.Артикул));
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 2, Строка(СтрокаДанных.Номенклатура));
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 3, ФорматЧисла(СтрокаДанных.КоличествоПродано));
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 4, ФорматЧисла(СтрокаДанных.Остаток));
	УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, 5, ФорматЧисла(СтрокаДанных.ЗакупочнаяЦена));
	
КонецПроцедуры

&НаСервере
Процедура ОформитьЗаголовокОтчета(ТабличныйДокумент)
	
	ОбластьЗаголовка = ТабличныйДокумент.Область(1, 1, 1, 5);
	ОбластьЗаголовка.Объединить();
	ОбластьЗаголовка.Шрифт = Новый Шрифт(ОбластьЗаголовка.Шрифт, , 14, Истина);
	
КонецПроцедуры

&НаСервере
Процедура ОформитьШапкуТаблицы(ТабличныйДокумент, НомерСтроки)
	
	ОбластьШапки = ТабличныйДокумент.Область(НомерСтроки, 1, НомерСтроки, 5);
	ОбластьШапки.Шрифт = Новый Шрифт(ОбластьШапки.Шрифт, , , Истина);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьТекстЯчейки(ТабличныйДокумент, НомерСтроки, НомерКолонки, ТекстЯчейки)
	
	ОбластьЯчейки = ТабличныйДокумент.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки);
	ОбластьЯчейки.Текст = ТекстЯчейки;
	УстановитьГраницыЯчейки(ОбластьЯчейки);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьГраницыЯчейки(ОбластьЯчейки)
	
	ЛинияГраницы = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
	
	ОбластьЯчейки.ГраницаСлева = ЛинияГраницы;
	ОбластьЯчейки.ГраницаСверху = ЛинияГраницы;
	ОбластьЯчейки.ГраницаСправа = ЛинияГраницы;
	ОбластьЯчейки.ГраницаСнизу = ЛинияГраницы;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьШиринуКолонки(ТабличныйДокумент, НомерКолонки, ШиринаКолонки)
	
	ОбластьКолонки = ТабличныйДокумент.Область(1, НомерКолонки, 1, НомерКолонки);
	ОбластьКолонки.ШиринаКолонки = ШиринаКолонки;
	
КонецПроцедуры

&НаСервере
Функция ПредставлениеВидаЦены(ВидЗакупочнойЦены)
	
	Если ЗначениеЗаполнено(ВидЗакупочнойЦены) Тогда
		Возврат Строка(ВидЗакупочнойЦены);
	КонецЕсли;
	
	Возврат "не найден, цена будет 0";
	
КонецФункции

&НаСервере
Функция ФорматЧисла(Значение)
	
	Возврат Формат(Значение, "ЧДЦ=3; ЧГ=0");
	
КонецФункции

#КонецОбласти
